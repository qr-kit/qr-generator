{
  "name": "@qr-kit/react",
  "version": "1.0.1",
  "description": "React component and hook for QR code generation — shapes, gradients, logos, overlays, frames, and finder pattern customization",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@qr-kit/core": "workspace:*",
    "@qr-kit/dom": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "jsdom": "^29.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "keywords": [
    "qr",
    "qr-code",
    "qrcode",
    "react",
    "react-qr",
    "qr-component",
    "qr-hook",
    "svg",
    "qr-styling",
    "qr-logo"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qr-kit/qr-generator.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/qr-kit/qr-generator/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/qr-kit/qr-generator/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
